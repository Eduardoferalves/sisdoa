{
  "outputDirectory": "web/dist",
  "rewrites": [
    {
      "source": "/donations(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(docs|redoc|openapi.json)(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
